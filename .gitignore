# =============================================================================
# .gitignore for CMZMod
# =============================================================================
# Public repo. Source code is committed; copyrighted game assets and
# build artifacts are not.
# =============================================================================

# -----------------------------------------------------------------------------
# Build artifacts (regenerated by deploy.ps1 / MSBuild)
# -----------------------------------------------------------------------------
bin/
obj/
[Bb]in/
[Oo]bj/
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio working files
.vs/
*.vspx
*.sap

# ReSharper, Rider
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/

# -----------------------------------------------------------------------------
# Game assets (copyrighted - never commit these)
# -----------------------------------------------------------------------------
# cmz_extracted/ is generated from a retail STFS and contains DigitalDNA's
# packaged binaries, dashboard metadata, localized resource DLLs, and the
# Content/ folder. Anyone working on the project must extract their own copy
# via setup_assets.ps1.
cmz_extracted/
deploy/

# Backups of source / pre-migration state
backup_144/
backup_*/

# XNA installer extraction directory
xna_extract/

# Retail STFS files and built mod STFS files (huge, contain copyrighted assets)
*.stfs
Castle_Miner_Z
Castle Miner Z

# -----------------------------------------------------------------------------
# Decompilation outputs (regenerated, can be huge)
# -----------------------------------------------------------------------------
cmz_*_decomp/
*.decompiled/
ilspy_output/

# Generated build/run logs
build_output.txt
build_log.txt
output.txt
listing.txt
*.binlog
*.log

# -----------------------------------------------------------------------------
# STFS CLI build artifacts
# -----------------------------------------------------------------------------
# Velocity is cloned by build_windows.bat; built binaries are produced locally.
stfs-cli/Velocity/
stfs-cli/*.exe
stfs-cli/*.o
stfs-cli/*.obj

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Local-only files (notes, secrets, environment-specific)
# -----------------------------------------------------------------------------
*.local.md
*.local.ps1
*.local.txt
.env
.env.local
ftp_creds.txt
console_ip.txt
.UntrackedLocal/
build_temp/
mods/

# -----------------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

# Editors
*.swp
*.swo
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.old
*.orig
*.rej
scratch/
tmp/
temp/
